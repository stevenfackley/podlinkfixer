# Copy to .dev.vars and fill in. Never commit .dev.vars.
# Podcast Index: https://podcastindex.org/  (free account, get key + secret)
PODCAST_INDEX_KEY=your_key_here
PODCAST_INDEX_SECRET=your_secret_here

# Spotify: https://developer.spotify.com/dashboard  (create app, Client Credentials flow)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
